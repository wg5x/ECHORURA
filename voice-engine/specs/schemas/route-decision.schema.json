{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echorura.com/schemas/voice-engine/route-decision.schema.json",
  "title": "RouteDecision",
  "type": "object",
  "required": ["type", "session_id", "turn_id", "mode", "confidence"],
  "additionalProperties": false,
  "properties": {
    "type": {
      "const": "route_decision"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "turn_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["chat", "scenario", "native_action", "server_action", "clarify", "reject"]
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "scenario_id": {
      "type": "string",
      "minLength": 1
    },
    "scenario_intent": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "need_clarification": {
      "type": "boolean",
      "default": false
    },
    "requires_confirmation": {
      "type": "boolean",
      "default": false
    },
    "arguments": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": {
            "const": "scenario"
          }
        }
      },
      "then": {
        "required": ["scenario_id", "scenario_intent"]
      }
    }
  ]
}
