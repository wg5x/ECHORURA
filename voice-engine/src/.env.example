PORT=8787

# Required for the real Volcengine realtime speech WebSocket.
VOLC_API_APP_ID=
VOLC_API_ACCESS_KEY=

# Fixed by Volcengine docs for this API.
VOLC_API_APP_KEY=PlgvMymc7f3tQnJ6
VOLC_API_RESOURCE_ID=volc.speech.dialog
VOLC_WS_URL=wss://openspeech.bytedance.com/api/v3/realtime/dialogue

# Required for the default StartSession because web search is enabled by default.
VOLC_WEBSEARCH_API_KEY=

# Disabled by default. Set true in local test env to save input/output WAV files.
VOICE_RECORDING_ENABLED=false
VOICE_RECORDINGS_DIR=data/recordings

# Disabled by default. Set true locally to save redacted S2S debug JSONL events.
VOICE_DEBUG_LOG_ENABLED=false
VOICE_DEBUG_LOG_DIR=data/debug-events

# Local archives used by memory, audits, and retention jobs.
VOICE_CONVERSATIONS_DIR=data/conversations
VOICE_MEMORIES_DIR=data/memories
VOICE_AUDIT_REPORTS_DIR=data/audit-reports

# Optional offline model auditor. This is not used by realtime routing.
MODEL_AUDIT_BASE_URL=https://apihub.agnes-ai.com/v1
MODEL_AUDIT_API_KEY=
MODEL_AUDIT_MODEL=agnes-2.0-flash
